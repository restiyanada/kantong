# Amount field encryption (AES-256-GCM). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
KANTONG_ENCRYPTION_KEY=

# Firebase Admin SDK service account (Firestore).
# From Firebase Console > Project Settings > Service Accounts > Generate new private key.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste the private key with literal \n for newlines (keep the quotes).
FIREBASE_PRIVATE_KEY=""

# Telegram bot (from @BotFather).
TELEGRAM_BOT_TOKEN=
# Random string you choose; set the same value when registering the webhook
# with Telegram so incoming requests can be verified.
TELEGRAM_WEBHOOK_SECRET=

# Web app light access gate (PRD section 3/8) — not a full auth system,
# just a shared passphrase. Pick any string.
WEB_ACCESS_PASSWORD=

# Shared secret between Apps Script and /api/email (PRD_Auto_Log_Bank_Emails).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
EMAIL_API_SECRET=

# Your personal Telegram chat ID (a number) — the digest is a proactive
# push, not a reply, so there's no incoming message to read a chat ID from.
# Message your bot anything, then check the "chat":{"id":...} field via
# https://api.telegram.org/bot<TELEGRAM_BOT_TOKEN>/getUpdates
TELEGRAM_CHAT_ID=

# Set by you; Vercel Cron automatically sends this as a Bearer token when
# it invokes /api/cron/digest, so the route can verify the request is
# really from Vercel's scheduler.
CRON_SECRET=
